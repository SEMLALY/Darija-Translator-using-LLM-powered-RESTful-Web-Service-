{
  "manifest_version": 3,
  "name": "Darija Translator (Side Panel)",
  "version": "1.0.0",
  "description": "Translate selected English text to Moroccan Darija using a secured REST API.",
  "permissions": ["contextMenus", "sidePanel", "storage"],
  "host_permissions": ["http://localhost:8080/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Darija Translator"
  }
}
